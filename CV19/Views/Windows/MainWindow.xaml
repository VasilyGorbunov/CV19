<Window x:Class="CV19.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CV19.ViewModels"
        xmlns:l="clr-namespace:CV19"
        mc:Ignorable="d"
        Title="{Binding Title}" 
        Height="700" 
        Width="1200">

  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>

  <DockPanel>

    <!--#region Main Menu -->
    <Menu DockPanel.Dock="Top" Margin="0 0 0 10">
      <MenuItem Header="Файл">
        <MenuItem Header="Выход"></MenuItem>
      </MenuItem>
      <MenuItem Header="Помощь">
        <MenuItem Header="О программе"/>
      </MenuItem>
    </Menu>
    <!--#endregion-->

    <!--#region Status Bar -->
    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem MinWidth="150" MaxWidth="300">
        <TextBlock Text="Status Text"/>
      </StatusBarItem>
      <StatusBarItem>
        <ProgressBar Width="320" Height="14" Value="72" Margin="10 0 0 0"/>
      </StatusBarItem>
    </StatusBar>
    <!--#endregion-->

    <!--#region Tab Control -->
    <TabControl>
      <!--#region Вкладка 1 -->
      <TabItem Header="Вкладка 1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <GridSplitter Grid.Column="0" Grid.RowSpan="2"
                        HorizontalAlignment="Right"
                        Width="3" 
                        Background="DarkOliveGreen"
                        />

          <Rectangle Grid.Row="0" Grid.Column="0"
                     Margin="15"
                     Fill="RoyalBlue"
                     StrokeThickness="5"
                     Stroke="DarkOrange"
                     RadiusX="8"
                     RadiusY="8"/>
          
          <Ellipse Grid.Row="0" Grid.Column="1"
                   Margin="15"
                   Fill="DarkOrange"
                   Stroke="RoyalBlue"
                   StrokeThickness="5"
                   />

        </Grid>
      </TabItem>
      <!--#endregion-->
      <!--#region Вкладка 2 -->
      <TabItem Header="Вкладка 2"></TabItem>
      <!--#endregion-->
    </TabControl>
    <!--#endregion-->

  </DockPanel>
</Window>
