<Window x:Class="CV19.Views.Windows.StringValueDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CV19.Views.Windows"
        mc:Ignorable="d"
        Title="StringValueDialogWindow" Height="208" Width="343">
  <DockPanel Margin="10">
    <UniformGrid DockPanel.Dock="Bottom" 
                 Rows="1" 
                 HorizontalAlignment="Right" 
                 Margin="7"
                 Button.Click="OnButtonClick">

      <Button Content="Ok" 
              IsDefault="True" 
              Margin="5 0" 
              Padding="30 5" 
              FontWeight="Bold"/>

      <Button Content="Cancel" 
              IsCancel="True" 
              Margin="5 0" 
              Padding="30 5"/>

    </UniformGrid>
    <TextBlock DockPanel.Dock="Top" Text="Сообщение" Name="MessageTextBlock" Margin="0 10"/>
    <TextBox Name="ValueTextBox" />
  </DockPanel>
</Window>
